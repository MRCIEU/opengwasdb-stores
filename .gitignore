# Raw GWAS Catalog source data (100+ MB); source data lives outside the repo
# and is referenced by URI (see README). Download separately into resources/data/.
resources/data/*.tsv

# Generated by resources/scripts/ebi-studies.r; regenerate rather than commit.
resources/data/derived/

# Rendered Quarto output; regenerate with `quarto render resources/scripts/*.qmd`.
resources/scripts/*.html
resources/scripts/*_files/
resources/scripts/*_cache/
resources/scripts/.quarto/

# Large downloaded summary statistics used by mvp-imputation-filters.qmd.
resources/data/mvp-example/

# Ragged-store spike: transient downloads + filtered outputs (regenerate).
resources/data/ragged-spike/
